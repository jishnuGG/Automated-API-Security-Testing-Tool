{
    "manifest_version": 3,
    "name": "API Security Monitor",
    "version": "1.1",
    "description": "Real-time API security monitoring and risk assessment.",
    "permissions": [
        "activeTab",
        "storage",
        "webRequest",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html"
    }
}